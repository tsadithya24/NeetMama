@page
@model IndexModel
@{
    ViewData["Title"] = "NEET Mama";
}

<div class="text-center mt-5">

    <h1 class="display-2 fw-bold text-primary">
        NEET Mama
    </h1>

    <p class="lead fs-3">
        Learn Smarter. Practice Better. Rank Higher.
    </p>

    <p class="text-muted fs-5">
        AI-Powered Question Generation, Adaptive Testing, Performance Analytics,
        and Personalized Learning for NEET Aspirants.
    </p>

    <hr class="my-4" />

    <div class="row justify-content-center mt-4">

        <div class="col-md-3 mb-3">
            <div class="card shadow">
                <div class="card-body">
                    <h4>📚 AI Question Bank</h4>
                    <p>
                        Generate unlimited NEET-style questions based on NCERT and previous year papers.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow">
                <div class="card-body">
                    <h4>📝 Smart Tests</h4>
                    <p>
                        Create chapter-wise, unit-wise and full NEET mock tests instantly.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow">
                <div class="card-body">
                    <h4>📊 Performance Analytics</h4>
                    <p>
                        Identify strengths, weaknesses and track progress with detailed insights.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-5">

        <a class="btn btn-primary btn-lg me-3"
           href="/Teachers/Dashboard">
            Teacher Dashboard
        </a>

        <a class="btn btn-success btn-lg"
           href="/Students/Dashboard">
            Student Dashboard
        </a>

    </div>

    <div class="mt-5">
        <blockquote class="blockquote">
            <p class="mb-0">
                "Success in NEET is not about studying more,
                it's about practicing smarter every day."
            </p>
        </blockquote>
    </div>

</div>
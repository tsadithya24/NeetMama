@page
@model NeetMama.Pages.Teachers.AIGenerateFlashCardsModel

<h1>AI Flash Card Generator</h1>

<hr />

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">
        @Model.Message
    </div>
}

<form method="post">

    <div class="mb-3">
        <label class="form-label">Subject</label>
        <select asp-for="Input.Subject" class="form-control">
            <option value="">Select Subject</option>
            <option value="Biology">Biology</option>
            <option value="Physics">Physics</option>
            <option value="Chemistry">Chemistry</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Topic</label>
        <input asp-for="Input.Topic"
               class="form-control"
               placeholder="Example: Human Reproduction Fertilisation zona pellucida acrosome" />
    </div>

    <div class="mb-3">
        <label class="form-label">Card Type</label>
        <select asp-for="Input.CardType" class="form-control">
            <option value="Concept">Concept</option>
            <option value="Definition">Definition</option>
            <option value="ScientistFact">Scientist / Experiment</option>
            <option value="Formula">Formula</option>
            <option value="Reaction">Reaction</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Number of Flash Cards</label>
        <input asp-for="Input.Count"
               class="form-control"
               type="number"
               min="1"
               max="30" />
    </div>

    <button type="submit" class="btn btn-success">
        Generate Flash Cards
    </button>

    <a href="/Teachers/Dashboard" class="btn btn-secondary">
        Back
    </a>

</form>
@page
@model NeetMama.Pages.Teachers.UploadedDocumentsModel

<h1>Uploaded Documents</h1>

<hr />
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}
<a class="btn btn-primary mb-3" href="/Teachers/UploadBooks">
    Upload New Document
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Subject</th>
            <th>Class Level</th>
            <th>Document Type</th>
            <th>File Name</th>
            <th>Uploaded Date</th>
            <th>View</th>
            <th>Delete</th>
            <th>Status</th>
            <th>Processed Date</th>
            <th>Process</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var book in Model.UploadedBooks)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Subject</td>
                <td>@book.ClassLevel</td>
                <td>@book.DocumentType</td>
                <td>@book.FileName</td>
                <td>@book.UploadedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                <td>
                    <a class="btn btn-sm btn-info"
                       href="@book.FilePath"
                       target="_blank">
                        View PDF
                    </a>
                </td>
                <td>
                    <form method="post"
                          asp-page-handler="Delete">

                        <input type="hidden"
                               name="id"
                               value="@book.Id" />

                        <button type="submit"
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Delete this document?');">
                            Delete
                        </button>

                    </form>
                </td>
                <td>
                    @if (book.IsProcessed)
                    {
                        <span class="badge bg-success">Processed</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending</span>
                    }
                </td>
                <td>
                    @(book.ProcessedDate.HasValue
                                    ? book.ProcessedDate.Value.ToString("dd-MMM-yyyy hh:mm tt")
                                    : "-")
                </td>
                <td>
                @if (!book.IsProcessed)
                    {
                        <form method="post" asp-page-handler="Process">
                            <input type="hidden" name="id" value="@book.Id" />

                            <button type="submit" class="btn btn-sm btn-success">
                                Process
                            </button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-secondary" disabled>
                            Done
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
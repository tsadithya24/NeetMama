@page
@model NeetMama.Pages.Teachers.UploadedDocumentsModel

<h1>Uploaded Documents</h1>

<hr />

<a class="btn btn-primary mb-3" href="/Teachers/UploadBooks">
    Upload New Document
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Subject</th>
            <th>Class Level</th>
            <th>Document Type</th>
            <th>File Name</th>
            <th>Uploaded Date</th>
            <th>View</th>
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var book in Model.UploadedBooks)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Subject</td>
                <td>@book.ClassLevel</td>
                <td>@book.DocumentType</td>
                <td>@book.FileName</td>
                <td>@book.UploadedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                <td>
                    <a class="btn btn-sm btn-info"
                       href="@book.FilePath"
                       target="_blank">
                        View PDF
                    </a>
                </td>
                <td>
                    <form method="post"
                          asp-page-handler="Delete">

                        <input type="hidden"
                               name="id"
                               value="@book.Id" />

                        <button type="submit"
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Delete this document?');">
                            Delete
                        </button>

                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>